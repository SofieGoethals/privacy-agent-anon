# Copy this file to .env and fill in your key.
# Get an API key at https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: override the judge model (default: google/gemini-2.0-flash-001)
# JUDGE_MODEL=google/gemini-2.0-flash-001

# Optional: override the judge base URL (default: https://openrouter.ai/api/v1)
# JUDGE_BASE_URL=https://openrouter.ai/api/v1
